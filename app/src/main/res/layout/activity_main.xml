<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/bg_primary"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="52dp"
            android:paddingBottom="20dp">

            <!-- Title row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Logo circle -->
                <LinearLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/badge_green"
                    android:gravity="center">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Т"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Такса"
                        android:textColor="@color/text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.01"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"
                        android:text="Автобот для inDrive · v6"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- BOT TOGGLE CARD -->
            <LinearLayout
                android:id="@+id/cardBotToggle"
                android:layout_width="match_parent"
                android:layout_height="76dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_status_off"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="18dp"
                android:paddingEnd="14dp">

                <TextView
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/badge_gray"
                    android:layout_marginEnd="14dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tvStatusLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="БОТ ОСТАНОВЛЕН"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.03"/>
                    <TextView
                        android:id="@+id/tvStatusDesc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Нажмите переключатель для запуска"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"/>
                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchAutoAccept"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:thumbTint="@color/white"
                    app:trackTint="@color/primary"/>
            </LinearLayout>
        </LinearLayout>

        <!-- PERMISSION WARNING -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardPermission"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="4dp"
            android:visibility="gone"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#1F1510">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Требуются разрешения"
                    android:textColor="#FF6D00"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Специальные возможности и наложение поверх приложений"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGrantPermissions"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="#FF6D00"
                    android:text="Выдать разрешения"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    app:cornerRadius="10dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- STATS ROW -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:weightSum="4">

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="5dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/green_bg">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="14dp" android:gravity="center">
                    <TextView android:id="@+id/tvAccepted"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textColor="@color/green_500"
                        android:textSize="26sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Принято" android:textColor="@color/green_500"
                        android:textSize="10sp" android:layout_marginTop="3dp" android:alpha="0.7"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                android:layout_marginEnd="5dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/red_bg">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="14dp" android:gravity="center">
                    <TextView android:id="@+id/tvRejected"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textColor="@color/red_500"
                        android:textSize="26sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Пропуск" android:textColor="@color/red_500"
                        android:textSize="10sp" android:layout_marginTop="3dp" android:alpha="0.7"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                android:layout_marginEnd="5dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/blue_bg">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="14dp" android:gravity="center">
                    <TextView android:id="@+id/tvCalls"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textColor="@color/blue_500"
                        android:textSize="26sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Звонки" android:textColor="@color/blue_500"
                        android:textSize="10sp" android:layout_marginTop="3dp" android:alpha="0.7"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#16181F">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="14dp" android:gravity="center">
                    <TextView android:id="@+id/tvEarnings"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0T" android:textColor="@color/accent_yellow"
                        android:textSize="20sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Доход" android:textColor="@color/accent_yellow"
                        android:textSize="10sp" android:layout_marginTop="3dp" android:alpha="0.7"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- MODE CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="14dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/bg_card">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="РЕЖИМ РАБОТЫ"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="14dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_tab_container"
                    android:orientation="horizontal"
                    android:padding="4dp"
                    android:weightSum="3">
                    <TextView
                        android:id="@+id/btnModeAll"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Город"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:background="@drawable/bg_pill_unselected"/>
                    <TextView
                        android:id="@+id/btnModeIntercity"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="3dp"
                        android:gravity="center"
                        android:text="Посылки"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:background="@drawable/bg_pill_unselected"/>
                    <TextView
                        android:id="@+id/btnModeCarpool"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="3dp"
                        android:gravity="center"
                        android:text="Попутки"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:background="@drawable/bg_pill_unselected"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvModeDesc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/badge_info_bg"
                    android:padding="10dp"
                    android:text=""
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:visibility="gone"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- FILTERS CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="10dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/bg_card">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="ФИЛЬТРЫ ЦЕН"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.12"/>
                    <TextView
                        android:id="@+id/btnEditFilters"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Изменить"
                        android:textColor="@color/primary"
                        android:textSize="13sp"
                        android:padding="4dp"/>
                </LinearLayout>

                <!-- Город -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_status_card"
                    android:padding="14dp"
                    android:layout_marginBottom="8dp">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Городская доставка"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"/>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="3dp">
                            <TextView
                                android:id="@+id/tvMinPrice"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="2 000 T"
                                android:textColor="@color/text_primary"
                                android:textSize="18sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:id="@+id/tvCityPriceMode"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=" · от мин."
                                android:textColor="@color/text_secondary"
                                android:textSize="11sp"/>
                        </LinearLayout>
                    </LinearLayout>
                    <TextView
                        android:id="@+id/tvMinPriceStatus"
                        android:layout_width="46dp"
                        android:layout_height="24dp"
                        android:gravity="center"
                        android:background="@drawable/badge_green"
                        android:text="ВКЛ"
                        android:textColor="@color/white"
                        android:textSize="10sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- Посылки -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_status_card"
                    android:padding="14dp"
                    android:layout_marginBottom="8dp">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Посылки межгород"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"/>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="3dp">
                            <TextView
                                android:id="@+id/tvMinIntercityPrice"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="5 000 T"
                                android:textColor="@color/text_primary"
                                android:textSize="18sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:id="@+id/tvIntercityPriceMode"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=" · от мин."
                                android:textColor="@color/text_secondary"
                                android:textSize="11sp"/>
                        </LinearLayout>
                    </LinearLayout>
                    <TextView
                        android:id="@+id/tvMinIntercityStatus"
                        android:layout_width="46dp"
                        android:layout_height="24dp"
                        android:gravity="center"
                        android:background="@drawable/badge_green"
                        android:text="ВКЛ"
                        android:textColor="@color/white"
                        android:textSize="10sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- Попутчики -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_status_card"
                    android:padding="14dp">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Попутчики"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"/>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="3dp">
                            <TextView
                                android:id="@+id/tvMinCarpoolPrice"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="5 000 T"
                                android:textColor="@color/text_primary"
                                android:textSize="18sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:id="@+id/tvCarpoolPriceMode"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=" · от мин."
                                android:textColor="@color/text_secondary"
                                android:textSize="11sp"/>
                        </LinearLayout>
                    </LinearLayout>
                    <TextView
                        android:id="@+id/tvMinCarpoolStatus"
                        android:layout_width="46dp"
                        android:layout_height="24dp"
                        android:gravity="center"
                        android:background="@drawable/badge_green"
                        android:text="ВКЛ"
                        android:textColor="@color/white"
                        android:textSize="10sp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- CITIES CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="10dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/bg_card">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Города назначения"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="Принимать только в выбранные города"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"/>
                    </LinearLayout>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchCityFilter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:thumbTint="@color/white"
                        app:trackTint="@color/primary"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvSelectedCities"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_status_card"
                    android:padding="12dp"
                    android:text="Не выбрано"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:alpha="0.5"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEditCities"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="@color/bg_surface"
                    android:text="Выбрать города"
                    android:textAllCaps="false"
                    android:textColor="@color/primary"
                    android:textSize="13sp"
                    app:cornerRadius="10dp"
                    app:strokeColor="@color/primary"
                    app:strokeWidth="1dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- AUTO CALL CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="10dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/bg_card">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Авто-звонок"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="Звонит автоматически при подходящем заказе"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"/>
                    </LinearLayout>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchAutoCall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:thumbTint="@color/white"
                        app:trackTint="@color/primary"/>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Задержка перед звонком"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"/>
                        <TextView
                            android:id="@+id/tvCallDelay"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Мгновенно"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                    <TextView
                        android:id="@+id/btnCallDelayEdit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Изменить"
                        android:textColor="@color/primary"
                        android:textSize="13sp"
                        android:padding="4dp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- LAST ORDER CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="10dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/bg_card">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ПОСЛЕДНИЙ ЗАКАЗ"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="10dp"/>
                <TextView
                    android:id="@+id/tvLastOrder"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Заказов пока нет. Запустите Такса и откройте inDrive."
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:lineSpacingExtra="4dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- BOTTOM BUTTONS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="32dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStats"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:backgroundTint="@color/bg_card"
                android:text="Журнал заказов"
                android:textAllCaps="false"
                android:textColor="@color/blue_500"
                android:textSize="14sp"
                app:cornerRadius="14dp"
                app:strokeColor="@color/blue_500"
                app:strokeWidth="1dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSettings"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:backgroundTint="@color/bg_card"
                android:text="Разрешения"
                android:textAllCaps="false"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                app:cornerRadius="14dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
