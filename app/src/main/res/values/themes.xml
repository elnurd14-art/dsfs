<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.InDriverBot" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/bg_primary</item>
        <item name="colorAccent">@color/primary</item>
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:navigationBarColor">@color/bg_primary</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="switchStyle">@style/GreenSwitch</item>
    </style>

    <style name="DarkDialogTheme" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="android:background">#111520</item>
        <item name="android:textColor">#EDEEF5</item>
        <item name="colorPrimary">#00E676</item>
        <item name="colorAccent">#00E676</item>
        <item name="android:textColorPrimary">#EDEEF5</item>
        <item name="android:textColorSecondary">#636880</item>
        <item name="materialAlertDialogTitleTextStyle">@style/DarkDialogTitle</item>
    </style>

    <style name="DarkDialogTitle" parent="MaterialAlertDialog.MaterialComponents.Title.Text">
        <item name="android:textColor">#EDEEF5</item>
        <item name="android:textSize">18sp</item>
    </style>

    <style name="GreenSwitch" parent="Widget.MaterialComponents.CompoundButton.Switch">
        <item name="thumbTint">@color/white</item>
        <item name="trackTint">@color/primary</item>
    </style>
</resources>
